generator client {
  provider   = "prisma-client-js"
  // Engine-less client (query compiler, no Rust engine / no fs access) so it
  // runs on Cloudflare Workers. Pairs with the Neon driver adapter in db.ts.
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionSource {
  MANUAL
  SLIP_SCAN
  BANK_IMPORT
  AI_INFERRED
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum AiReportType {
  SLIP_EXTRACTION
  SPENDING_ANALYSIS
  BUDGET_RECOMMENDATION
  GOAL_COACHING
  RISK_ALERT
}

model User {
  id                  String          @id @default(cuid())
  name                String
  email               String          @unique
  passwordHash        String?
  resetTokenHash      String?         @unique
  resetTokenExpiresAt DateTime?
  authProvider        String          @default("credentials")
  googleId            String?         @unique
  imageUrl            String?
  monthlyIncome       Decimal         @default(0) @db.Decimal(12, 2)
  savingGoal          Decimal         @default(0) @db.Decimal(12, 2)
  financialPreference String          @default("BALANCED")
  currency            String          @default("USD")
  locale              String          @default("en-US")
  timezone            String          @default("Asia/Bangkok")
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  categories          Category[]
  transactions        Transaction[]
  budgets             Budget[]
  goals               FinancialGoal[]
  aiReports           AiReport[]
  wealthItems         WealthItem[]
  netWorthSnapshots   NetWorthSnapshot[]
  subscriptions       Subscription[]

  @@index([email])
  @@index([googleId])
}

model Subscription {
  id            String    @id @default(cuid())
  userId        String
  name          String
  amount        Decimal   @db.Decimal(12, 2)
  currency      String    @default("USD")
  frequency     String    @default("monthly") // monthly | quarterly | yearly
  status        String    @default("active") // active | cancelled
  nextPaymentAt DateTime?
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id           String        @id @default(cuid())
  userId       String
  name         String
  color        String        @default("#087f7a")
  icon         String        @default("Wallet")
  isSystem     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@unique([userId, name])
  @@index([userId])
}

model Transaction {
  id             String            @id @default(cuid())
  userId         String
  categoryId     String?
  type           TransactionType
  source         TransactionSource @default(MANUAL)
  merchant       String
  description    String?
  amount         Decimal           @db.Decimal(12, 2)
  currency       String            @default("USD")
  occurredAt     DateTime
  slipImageUrl   String?
  slipRawText    String?
  aiConfidence   Float?
  aiMetadata     Json?
  isFavorite     Boolean           @default(false)
  tags           String[]          @default([])
  deletedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category       Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  aiReports      AiReport[]

  @@index([userId, occurredAt])
  @@index([userId, categoryId])
  @@index([userId, deletedAt])
  @@index([source])
}

model Budget {
  id          String       @id @default(cuid())
  userId      String
  categoryId  String?
  name        String
  amount      Decimal      @db.Decimal(12, 2)
  currency    String       @default("USD")
  period      BudgetPeriod @default(MONTHLY)
  startsAt    DateTime
  endsAt      DateTime?
  alertAtPct  Int          @default(80)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, isActive])
  @@index([userId, categoryId])
}

model FinancialGoal {
  id            String     @id @default(cuid())
  userId        String
  name          String
  targetAmount  Decimal    @db.Decimal(12, 2)
  currentAmount Decimal    @default(0) @db.Decimal(12, 2)
  currency      String     @default("USD")
  targetDate    DateTime?
  status        GoalStatus @default(ACTIVE)
  aiStrategy    Json?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

enum WealthItemType {
  CASH
  INVESTMENT
  PROPERTY
  DEBT
  LOAN
}

model WealthItem {
  id          String         @id @default(cuid())
  userId      String
  type        WealthItemType
  name        String
  value       Decimal        @db.Decimal(14, 2)
  currency    String         @default("USD")
  note        String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model NetWorthSnapshot {
  id         String   @id @default(cuid())
  userId     String
  assets     Decimal  @db.Decimal(14, 2)
  liabilities Decimal @db.Decimal(14, 2)
  netWorth   Decimal  @db.Decimal(14, 2)
  currency   String   @default("USD")
  snapshotAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, snapshotAt])
}

model AiReport {
  id            String       @id @default(cuid())
  userId        String
  transactionId String?
  type          AiReportType
  title         String
  summary       String
  insights      Json
  actions       Json?
  modelName     String?
  promptVersion String?
  confidence    Float?
  createdAt     DateTime     @default(now())
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([userId, type])
  @@index([transactionId])
}
